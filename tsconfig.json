{
	"compilerOptions": {
		"module": "commonjs",
		"moduleResolution": "node",
		"target": "ES2022",
		"lib": [
			"ES2022"
		],
		"sourceMap": true,
		"rootDir": "src",
		"outDir": "out",
		"strict": true,
		"resolveJsonModule": true,
		"esModuleInterop": true
	},
	"exclude": [
		"node_modules",
		"server"
	]
}
